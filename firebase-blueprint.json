{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and community referral tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "string" },
        "city": { "type": "string" },
        "profession": { "type": "string" },
        "jobTitle": { "type": "string" },
        "company": { "type": "string" },
        "education": { "type": "string" },
        "prompts": { 
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "temple": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "gender": { "type": "string" },
        "lookingFor": { "type": "string" },
        "photo": { "type": "string" },
        "voucherCode": { "type": "string" },
        "referredByCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "voucherCode", "referredByCode"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Mapping of voucher codes to their owners",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "ownerId"]
    },
    "LikeInteraction": {
      "title": "Like Interaction",
      "description": "A like sent from one user to another",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "toId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent between matched users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "text", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A report filed against a user",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reportedUserId": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "reportedUserId", "reason", "createdAt"]
    },
    "Block": {
      "title": "Block",
      "description": "A block between users",
      "type": "object",
      "properties": {
        "blockerId": { "type": "string" },
        "blockedUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blockerId", "blockedUserId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "vouchers/{code}": {
      "schema": "Voucher",
      "description": "Active voucher codes"
    },
    "likes/{likeId}": {
      "schema": "LikeInteraction",
      "description": "Tracks likes between users"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages between users"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Safety reports against users"
    },
    "blocks/{blockId}": {
      "schema": "Block",
      "description": "User blocks to prevent interaction"
    }
  }
}
