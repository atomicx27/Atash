rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isMasterCode(code) {
      return code == "21040721";
    }

    function isValidVoucher(code) {
      return isMasterCode(code) || exists(/databases/$(database)/documents/vouchers/$(code));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    isValidVoucher(incoming().referredByCode) &&
                    incoming().name is string && incoming().name.size() < 100 &&
                    incoming().voucherCode is string && incoming().voucherCode.size() == 8;
      allow update: if isSignedIn() && request.auth.uid == userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'name', 'age', 'city', 'profession', 'jobTitle', 'company', 'education', 'prompts', 'temple', 
                      'interests', 'gender', 'lookingFor', 'photo', 
                      'quizAnswers', 'email'
                    ]);
    }

    match /vouchers/{code} {
      allow read: if true; // Needed to check if code is valid before login
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId &&
                    code.size() == 8;
    }

    match /likes/{likeId} {
      allow read: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid && 
                    exists(/databases/$(database)/documents/users/$(incoming().toId)) &&
                    incoming().createdAt == request.time;
      allow delete: if isSignedIn() && resource.data.fromId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && 
                    incoming().createdAt == request.time &&
                    incoming().text is string && incoming().text.size() > 0 && incoming().text.size() <= 1000;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && incoming().reporterId == request.auth.uid &&
                    incoming().createdAt == request.time;
    }

    match /blocks/{blockId} {
      allow read: if isSignedIn() && resource.data.blockerId == request.auth.uid;
      allow create: if isSignedIn() && incoming().blockerId == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow delete: if isSignedIn() && resource.data.blockerId == request.auth.uid;
    }
  }
}
